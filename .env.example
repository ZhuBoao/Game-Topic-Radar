# 复制成 .env 再填

# 后端端口
PORT=3000

# claude 命令（默认 claude，可写绝对路径）
CLAUDE_BIN=claude

# OpenAI（缩略图出图 + 文字双模型对比用）
OPENAI_API_KEY=sk-xxx
# 文字生成用的 OpenAI 模型（和 claude 并排对比）
# 注意：没有 gpt-5.5-mini，5.5 这代只有 gpt-5.5 / gpt-5.5-pro；最新的 mini 是 gpt-5.4-mini
OPENAI_TEXT_MODEL=gpt-5.4-mini

# YouTube OAuth（拉自己频道视频用）
# 在 Google Cloud Console 建一个 OAuth 2.0 客户端（类型选 Web 应用）
# 授权重定向 URI 填：http://localhost:3000/oauth2callback
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
